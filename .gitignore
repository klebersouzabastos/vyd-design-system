# Dependencies
node_modules/

# Example app build output (the design-system's own /dist IS committed — see note below)
examples/*/dist/
examples/*/.next/
examples/*/out/
*.tsbuildinfo

# Build scratch (the .clean temp dir used by the build)
build/.clean/

# Logs / env
*.log
npm-debug.log*
.env
.env.*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Original upload wrapper (superseded by the structured repo)
files.zip

# NOTE: /dist IS committed on purpose (v0.1.0): apps consume built artifacts
# straight from GitHub since there is no npm publish yet. Once publishing is
# enabled, dist/ can be moved to npm-only and ignored here.
