# Dependencies
node_modules/

# vyd-react build output — gerado por `tsc -p tsconfig.build.json` e publicado
# pelo CI (release.yml). NÃO commitar; é artefato de build do pacote vyd-react.
react/dist/

# TS incremental build info
*.tsbuildinfo

# Playwright (regressão visual) — relatórios/saídas efêmeras; baselines em
# test/__screenshots__/ SÃO commitadas (ver docs/TESTING.md).
test-results/
playwright-report/
blob-report/
.playwright/

# Build scratch (the .clean temp dir used by the build)
build/.clean/

# Logs / env
*.log
npm-debug.log*
.env
.env.*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Original upload wrapper (superseded by the structured repo)
files.zip

# NOTE: /dist IS committed on purpose: apps consume built artifacts straight from
# GitHub (npm install github:…#vX.Y.Z) além do npm. O CI valida que o dist/
# commitado bate com o build (git diff --exit-code). Mantenha commitado.
