{
  "name": "vyd-design-system",
  "version": "1.0.0",
  "description": "VYD Design System — fonte única de verdade visual do ecossistema VYD (apps de engenharia). Estilo técnico, sóbrio, denso. Acento azul-blueprint.",
  "license": "MIT",
  "author": "K2+ / VYD",
  "type": "commonjs",
  "workspaces": [
    "react"
  ],
  "//workspaces": "react/ (vyd-react) é publicado como pacote PRÓPRIO; NÃO entra no 'files' deste pacote. Build/publish via .github/workflows/release.yml.",
  "main": "dist/tokens.js",
  "module": "dist/tokens.mjs",
  "types": "dist/tokens.d.ts",
  "exports": {
    ".": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.mjs",
      "require": "./dist/tokens.js"
    },
    "./theme.css": "./dist/theme.css",
    "./variables.css": "./dist/variables.css",
    "./shell.css": "./css/shell.css",
    "./tailwind": "./dist/tokens.tailwind.js",
    "./tokens.json": "./tokens/tokens.json",
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.mjs",
      "require": "./dist/icons.js"
    },
    "./icons.svg": "./dist/icons.svg",
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "css",
    "tokens",
    "icons",
    "build",
    "brand",
    "demo",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "node build/build.mjs && node build/build-icons.mjs",
    "build:icons": "node build/build-icons.mjs",
    "verify": "node build/verify.mjs",
    "icons": "python3 build/make-icons.py",
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "npm --workspace vyd-react run typecheck",
    "test": "npm run build && npm run verify && npm run typecheck",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "style-dictionary",
    "tailwind-preset",
    "css-variables",
    "vyd"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klebersouzabastos/vyd-design-system.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "style-dictionary": "^4.0.0"
  }
}
