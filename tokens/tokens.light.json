{
  "_meta": {
    "name": "VYD Design System — Light overrides",
    "description": "Overrides do TEMA CLARO. Contem APENAS os tokens semanticos que mudam em relacao ao dark (default). As primitivas (escalas de cor, tipo, espaco...) vivem em tokens.json e NAO sao redefinidas aqui — sem duplicacao de fonte de verdade. O build mescla este arquivo SOBRE tokens.json so para emitir o bloco [data-vyd-theme=\"light\"]."
  },

  "color": {
    "semantic": {
      "bg": {
        "chrome":   { "value": "{color.neutral.900}" },
        "panel":    { "value": "{color.neutral.1000}" },
        "canvas":   { "value": "{color.neutral.1000}" },
        "elevated": { "value": "{color.neutral.1000}" }
      },
      "text": {
        "primary":   { "value": "{color.neutral.100}" },
        "secondary": { "value": "{color.neutral.300}" },
        "disabled":  { "value": "{color.neutral.400}" },
        "inverse":   { "value": "{color.neutral.1000}" },
        "onAccent":  { "value": "{color.neutral.1000}" },
        "accent":    { "value": "{color.brand.blueprint.600}" }
      },
      "border": {
        "default": { "value": "{color.neutral.700}" },
        "strong":  { "value": "{color.neutral.600}" },
        "accent":  { "value": "{color.brand.blueprint.500}" }
      },
      "action": {
        "primary":      { "value": "{color.brand.blueprint.500}" },
        "primaryHover": { "value": "{color.brand.blueprint.600}" },
        "primaryActive":{ "value": "{color.brand.blueprint.700}" }
      }
    }
  }
}
