{
  "$extensions": {
    "vyd": {
      "meta": {
        "name": "VYD Design System — Light overrides",
        "description": "Overrides do TEMA CLARO. Contem APENAS os tokens semanticos que mudam em relacao ao dark (default). As primitivas (escalas de cor, tipo, espaco...) vivem em tokens.json e NAO sao redefinidas aqui — sem duplicacao de fonte de verdade. O build mescla este arquivo SOBRE tokens.json so para emitir o bloco [data-vyd-theme=\"light\"]."
      }
    }
  },
  "color": {
    "$type": "color",
    "semantic": {
      "bg": {
        "chrome": {
          "$value": "{color.neutral.900}"
        },
        "panel": {
          "$value": "{color.neutral.1000}"
        },
        "canvas": {
          "$value": "{color.neutral.1000}"
        },
        "elevated": {
          "$value": "{color.neutral.1000}"
        },
        "tooltip": {
          "$value": "{color.neutral.100}",
          "$description": "tooltip claro = chip escuro invertido (conserta o preto-no-preto pre-3.0)"
        }
      },
      "text": {
        "primary": {
          "$value": "{color.neutral.100}"
        },
        "secondary": {
          "$value": "{color.neutral.300}"
        },
        "disabled": {
          "$value": "{color.neutral.400}"
        },
        "inverse": {
          "$value": "{color.neutral.1000}"
        },
        "onAccent": {
          "$value": "{color.neutral.1000}"
        },
        "accent": {
          "$value": "{color.brand.accent.600}"
        },
        "tooltip": {
          "$value": "{color.neutral.1000}"
        }
      },
      "border": {
        "default": {
          "$value": "{color.neutral.700}"
        },
        "strong": {
          "$value": "{color.neutral.600}"
        },
        "accent": {
          "$value": "{color.brand.accent.500}"
        }
      },
      "action": {
        "primary": {
          "$value": "{color.brand.accent.500}"
        },
        "primaryHover": {
          "$value": "{color.brand.accent.600}"
        },
        "primaryActive": {
          "$value": "{color.brand.accent.700}"
        }
      },
      "feedback": {
        "dangerText": {
          "$value": "#C23A3A",
          "$description": "texto de erro sobre branco (5.30)"
        },
        "successText": {
          "$value": "#1E7A50",
          "$description": "texto de status positivo sobre branco (5.31)"
        },
        "warningText": {
          "$value": "#8A5B00",
          "$description": "texto de atencao sobre branco (5.87)"
        }
      }
    }
  }
}
