{
  "$schema": "https://design-tokens.org/schema.json",
  "_meta": {
    "name": "VYD Design System",
    "version": "0.1.0",
    "description": "Single source of truth para o ecossistema VYD. Estilo: tecnico, sobrio, denso. Acento: azul-blueprint. NAO editar valores soltos nos apps — alterar aqui e propagar.",
    "owner": "K2+ / VYD"
  },

  "color": {
    "_comment": "Base grafite/carvao para densidade de app profissional. Acento azul-blueprint unico. Tons funcionais sobrios.",

    "brand": {
      "blueprint": {
        "50":  { "value": "#EAF1FB" },
        "100": { "value": "#CBDDF5" },
        "200": { "value": "#9CBEEC" },
        "300": { "value": "#6B9CE0" },
        "400": { "value": "#3E7BD4" },
        "500": { "value": "#1E5FC4", "_comment": "Cor de marca primaria — azul-blueprint" },
        "600": { "value": "#184FA6" },
        "700": { "value": "#143F86" },
        "800": { "value": "#102F63" },
        "900": { "value": "#0B2245" }
      }
    },

    "neutral": {
      "_comment": "Escala grafite. 0 = quase preto (chrome do app), 50 = quase branco. Densidade > respiro.",
      "0":   { "value": "#0D1117", "_comment": "fundo chrome / top bar / status bar" },
      "50":  { "value": "#161B22", "_comment": "fundo de paineis (rails, inspector)" },
      "100": { "value": "#1F2630" },
      "200": { "value": "#2A323D" },
      "300": { "value": "#3A4350", "_comment": "bordas / divisores em dark" },
      "400": { "value": "#5A6573" },
      "500": { "value": "#7B8794", "_comment": "texto secundario / placeholder" },
      "600": { "value": "#9AA5B1" },
      "700": { "value": "#C2CAD3" },
      "800": { "value": "#E1E6EB" },
      "900": { "value": "#F2F5F8", "_comment": "fundo canvas em light mode" },
      "1000":{ "value": "#FFFFFF" }
    },

    "semantic": {
      "_comment": "Tokens semanticos — os apps consomem ESTES, nunca a escala bruta. Trocar dark/light = remapear so aqui (dark = default neste arquivo; light em tokens.light.json).",
      "bg": {
        "chrome":    { "value": "{color.neutral.0}",   "_comment": "top bar, ribbon, status bar" },
        "panel":     { "value": "{color.neutral.50}",  "_comment": "left rail, right inspector" },
        "canvas":    { "value": "{color.neutral.100}", "_comment": "area de trabalho central (dark)" },
        "elevated":  { "value": "{color.neutral.200}",  "_comment": "menus, popovers, dropdowns" }
      },
      "text": {
        "primary":   { "value": "{color.neutral.800}" },
        "secondary": { "value": "{color.neutral.500}" },
        "disabled":  { "value": "{color.neutral.400}" },
        "inverse":   { "value": "{color.neutral.0}" },
        "onAccent":  { "value": "{color.neutral.1000}", "_comment": "texto/icone sobre superficie de acento (ex. botao primario). Antes era neutral-1000 hardcoded no .vyd-btn." },
        "accent":    { "value": "{color.brand.blueprint.300}" }
      },
      "border": {
        "default":   { "value": "{color.neutral.300}" },
        "strong":    { "value": "{color.neutral.400}" },
        "accent":    { "value": "{color.brand.blueprint.500}" }
      },
      "action": {
        "primary":      { "value": "{color.brand.blueprint.500}" },
        "primaryHover": { "value": "{color.brand.blueprint.400}" },
        "primaryActive":{ "value": "{color.brand.blueprint.600}" }
      },
      "feedback": {
        "success": { "value": "#2E9E6B" },
        "warning": { "value": "#D9920A", "_comment": "ambar de obra — usado so para alertas, NAO como marca" },
        "danger":  { "value": "#D24545" },
        "info":    { "value": "{color.brand.blueprint.400}" }
      }
    }
  },

  "typography": {
    "_comment": "Par tipografico intencional. Sans tecnica para UI + mono para dados/medidas/codigos de engenharia.",
    "family": {
      "sans": { "value": "'Inter Tight', 'Inter', system-ui, sans-serif", "_comment": "UI — Inter Tight tem cara mais 'instrumento' que Inter pura" },
      "mono": { "value": "'JetBrains Mono', 'IBM Plex Mono', monospace", "_comment": "valores numericos, cotas, IDs, codigos" }
    },
    "size": {
      "_comment": "Escala compacta — app profissional, nao marketing. Base 13px.",
      "xs":   { "value": "11px" },
      "sm":   { "value": "12px" },
      "base": { "value": "13px", "_comment": "corpo padrao da UI" },
      "md":   { "value": "14px" },
      "lg":   { "value": "16px" },
      "xl":   { "value": "20px" },
      "2xl":  { "value": "26px" },
      "3xl":  { "value": "34px" }
    },
    "weight": {
      "regular":  { "value": "400" },
      "medium":   { "value": "500" },
      "semibold": { "value": "600" },
      "bold":     { "value": "700" }
    },
    "lineHeight": {
      "tight":  { "value": "1.2" },
      "normal": { "value": "1.45" },
      "relaxed":{ "value": "1.6" }
    },
    "letterSpacing": {
      "tight":  { "value": "-0.01em" },
      "normal": { "value": "0" },
      "wide":   { "value": "0.04em", "_comment": "labels de ribbon em caixa alta" }
    }
  },

  "space": {
    "_comment": "Grid base 4px. Densidade de app: a maioria dos gaps fica entre 4 e 12px.",
    "0":  { "value": "0px" },
    "1":  { "value": "2px" },
    "2":  { "value": "4px" },
    "3":  { "value": "6px" },
    "4":  { "value": "8px" },
    "5":  { "value": "12px" },
    "6":  { "value": "16px" },
    "7":  { "value": "24px" },
    "8":  { "value": "32px" },
    "9":  { "value": "48px" }
  },

  "radius": {
    "_comment": "Contido — 4 a 6px. NADA de 16px+ (marcador de cara-de-IA).",
    "none": { "value": "0px" },
    "sm":   { "value": "3px" },
    "md":   { "value": "5px", "_comment": "padrao de botoes/inputs/cards" },
    "lg":   { "value": "8px", "_comment": "maximo — so para containers grandes" },
    "full": { "value": "9999px", "_comment": "so para avatares/pills de status" }
  },

  "border": {
    "width": {
      "hairline": { "value": "1px", "_comment": "divisores — preferir linha a sombra" },
      "thick":    { "value": "2px", "_comment": "estado de foco / item ativo na ribbon" }
    }
  },

  "shadow": {
    "_comment": "Sombras minimas e duras. Hierarquia vem de linha+densidade, nao de blur difuso.",
    "none": { "value": "none" },
    "sm":   { "value": "0 1px 2px rgba(0,0,0,0.25)" },
    "md":   { "value": "0 2px 6px rgba(0,0,0,0.30)", "_comment": "popovers/dropdowns" },
    "focus":{ "value": "0 0 0 2px {color.brand.blueprint.500}" }
  },

  "layout": {
    "_comment": "Dimensoes invariantes do app shell — a 'ribbon Autodesk'. IGUAIS em TODA ferramenta VYD.",
    "topbar":    { "height": { "value": "44px" } },
    "ribbon":    {
      "_comment": "A ribbon = faixa de abas (tabs) + área de comandos agrupados.",
      "height":        { "value": "88px", "_comment": "altura da área de comandos (grupos)" },
      "tabsHeight":    { "value": "34px", "_comment": "altura da faixa de abas acima dos grupos" },
      "commandHeight": { "value": "48px", "_comment": "altura do botão de comando (tile) na ribbon" }
    },
    "leftRail":  { "width":  { "value": "240px" }, "collapsedWidth": { "value": "48px" } },
    "rightPanel":{ "width":  { "value": "300px" } },
    "statusbar": { "height": { "value": "26px" } }
  },

  "motion": {
    "_comment": "Rapido e funcional. App profissional nao floreia.",
    "duration": {
      "fast":   { "value": "120ms" },
      "normal": { "value": "200ms" }
    },
    "easing": {
      "standard": { "value": "cubic-bezier(0.2, 0, 0, 1)" }
    }
  }
}
