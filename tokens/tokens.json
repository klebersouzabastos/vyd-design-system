{
  "$extensions": {
    "vyd": {
      "meta": {
        "name": "VYD Design System",
        "version": "0.1.0",
        "description": "Single source of truth para o ecossistema VYD. Estilo: tecnico, sobrio, denso. Acento: azul-blueprint. NAO editar valores soltos nos apps — alterar aqui e propagar.",
        "owner": "K2+ / VYD"
      }
    }
  },
  "color": {
    "$type": "color",
    "$description": "Base grafite/carvao para densidade de app profissional. Acento azul-blueprint unico. Tons funcionais sobrios.",
    "brand": {
      "blueprint": {
        "50": {
          "$value": "#EAF1FB"
        },
        "100": {
          "$value": "#CBDDF5"
        },
        "200": {
          "$value": "#9CBEEC"
        },
        "300": {
          "$value": "#6B9CE0"
        },
        "400": {
          "$value": "#3E7BD4"
        },
        "500": {
          "$value": "#1E5FC4",
          "$description": "Cor de marca primaria — azul-blueprint"
        },
        "600": {
          "$value": "#184FA6"
        },
        "700": {
          "$value": "#143F86"
        },
        "800": {
          "$value": "#102F63"
        },
        "900": {
          "$value": "#0B2245"
        }
      },
      "accent": {
        "$description": "Tier de MARCA (white-label): os semanticos apontam para ca, nunca direto p/ blueprint. Rebrand = sobrescrever so --vyd-brand-accent-*.",
        "50": {
          "$value": "{color.brand.blueprint.50}"
        },
        "100": {
          "$value": "{color.brand.blueprint.100}"
        },
        "200": {
          "$value": "{color.brand.blueprint.200}"
        },
        "300": {
          "$value": "{color.brand.blueprint.300}"
        },
        "400": {
          "$value": "{color.brand.blueprint.400}"
        },
        "500": {
          "$value": "{color.brand.blueprint.500}"
        },
        "600": {
          "$value": "{color.brand.blueprint.600}"
        },
        "700": {
          "$value": "{color.brand.blueprint.700}"
        },
        "800": {
          "$value": "{color.brand.blueprint.800}"
        },
        "900": {
          "$value": "{color.brand.blueprint.900}"
        }
      }
    },
    "neutral": {
      "$description": "Escala grafite. 0 = quase preto (chrome do app), 50 = quase branco. Densidade > respiro.",
      "0": {
        "$value": "#0D1117",
        "$description": "fundo chrome / top bar / status bar"
      },
      "50": {
        "$value": "#161B22",
        "$description": "fundo de paineis (rails, inspector)"
      },
      "100": {
        "$value": "#1F2630"
      },
      "200": {
        "$value": "#2A323D"
      },
      "300": {
        "$value": "#3A4350",
        "$description": "bordas / divisores em dark"
      },
      "400": {
        "$value": "#5A6573"
      },
      "500": {
        "$value": "#7B8794",
        "$description": "texto secundario / placeholder"
      },
      "600": {
        "$value": "#9AA5B1"
      },
      "700": {
        "$value": "#C2CAD3"
      },
      "800": {
        "$value": "#E1E6EB"
      },
      "900": {
        "$value": "#F2F5F8",
        "$description": "fundo canvas em light mode"
      },
      "1000": {
        "$value": "#FFFFFF"
      }
    },
    "semantic": {
      "$description": "Tokens semanticos — os apps consomem ESTES, nunca a escala bruta. Trocar dark/light = remapear so aqui (dark = default neste arquivo; light em tokens.light.json).",
      "bg": {
        "chrome": {
          "$value": "{color.neutral.0}",
          "$description": "top bar, ribbon, status bar"
        },
        "panel": {
          "$value": "{color.neutral.50}",
          "$description": "left rail, right inspector"
        },
        "canvas": {
          "$value": "{color.neutral.100}",
          "$description": "area de trabalho central (dark)"
        },
        "elevated": {
          "$value": "{color.neutral.200}",
          "$description": "menus, popovers, dropdowns"
        },
        "tooltip": {
          "$value": "{color.neutral.0}",
          "$description": "fundo do tooltip (par com text.tooltip). Antes hardcoded neutral-0 no CSS — e QUEBRADO no light (preto no preto)."
        }
      },
      "text": {
        "primary": {
          "$value": "{color.neutral.800}"
        },
        "secondary": {
          "$value": "{color.neutral.700}",
          "$description": "WCAG AAA (>=7:1) sobre canvas/panel/chrome. Antes neutral.500 reprovava AA no canvas (4.16)."
        },
        "disabled": {
          "$value": "{color.neutral.500}",
          "$description": "isento por WCAG; mira usabilidade (>=3:1). Antes neutral.400 (2.92)."
        },
        "inverse": {
          "$value": "{color.neutral.0}"
        },
        "onAccent": {
          "$value": "{color.neutral.1000}",
          "$description": "texto/icone sobre superficie de acento (ex. botao primario). Antes era neutral-1000 hardcoded no .vyd-btn."
        },
        "accent": {
          "$value": "{color.brand.accent.200}",
          "$description": "AAA sobre panel escuro. Antes blueprint.300 (6.14)."
        },
        "tooltip": {
          "$value": "{color.neutral.800}",
          "$description": "texto do tooltip sobre bg.tooltip (AAA garantido no contrast gate)"
        }
      },
      "border": {
        "default": {
          "$value": "{color.neutral.400}",
          "$description": "divisor mais visivel. Antes neutral.300."
        },
        "strong": {
          "$value": "{color.neutral.500}"
        },
        "accent": {
          "$value": "{color.brand.accent.500}"
        }
      },
      "action": {
        "primary": {
          "$value": "{color.brand.accent.500}"
        },
        "primaryHover": {
          "$value": "{color.brand.accent.400}"
        },
        "primaryActive": {
          "$value": "{color.brand.accent.600}"
        }
      },
      "feedback": {
        "success": {
          "$value": "#2E9E6B"
        },
        "warning": {
          "$value": "#D9920A",
          "$description": "ambar de obra — usado so para alertas, NAO como marca"
        },
        "onWarning": {
          "$value": "{color.neutral.0}",
          "$description": "texto sobre superficie warning (badge). Antes neutral-0 cru no CSS; par >=4.5 no contrast gate."
        },
        "danger": {
          "$value": "#D24545"
        },
        "info": {
          "$value": "{color.brand.accent.400}"
        }
      },
      "control": {
        "$description": "Glifos desenhados de controles de formulario (seta do select, check do checkbox). O build gera as vars --vyd-icon-* (data-URIs) a partir DESTES tokens — nada de cor crua em css/.",
        "glyph": {
          "$value": "{color.neutral.500}",
          "$description": "seta do select (>=3:1 sobre panel/branco)"
        },
        "checkGlyph": {
          "$value": "{color.neutral.1000}",
          "$description": "check do checkbox sobre action.primary"
        }
      }
    },
    "viz": {
      "$description": "Paleta de dados. cat = categorica distinguivel no escuro, ancorada em azul, sobria (sem roxo). seq = tints blueprint p/ heatmap/escala.",
      "cat": {
        "1": {
          "$value": "#3E7BD4"
        },
        "2": {
          "$value": "#2AA6A0"
        },
        "3": {
          "$value": "#D9920A"
        },
        "4": {
          "$value": "#2E9E6B"
        },
        "5": {
          "$value": "#D24545"
        },
        "6": {
          "$value": "#9AA5B1"
        }
      },
      "seq": {
        "1": {
          "$value": "{color.brand.accent.200}"
        },
        "2": {
          "$value": "{color.brand.accent.400}"
        },
        "3": {
          "$value": "{color.brand.accent.500}"
        },
        "4": {
          "$value": "{color.brand.accent.700}"
        },
        "5": {
          "$value": "{color.brand.accent.900}"
        }
      }
    }
  },
  "typography": {
    "$description": "Par tipografico intencional. Sans tecnica para UI + mono para dados/medidas/codigos de engenharia.",
    "family": {
      "$type": "fontFamily",
      "sans": {
        "$value": "'Inter Tight', 'Inter', system-ui, sans-serif",
        "$description": "UI — Inter Tight tem cara mais 'instrumento' que Inter pura"
      },
      "mono": {
        "$value": "'JetBrains Mono', 'IBM Plex Mono', monospace",
        "$description": "valores numericos, cotas, IDs, codigos"
      }
    },
    "size": {
      "$type": "dimension",
      "$description": "Escala compacta — app profissional, nao marketing. Base 13px.",
      "xs": {
        "$value": "11px"
      },
      "sm": {
        "$value": "12px"
      },
      "base": {
        "$value": "13px",
        "$description": "corpo padrao da UI"
      },
      "md": {
        "$value": "14px"
      },
      "lg": {
        "$value": "16px"
      },
      "xl": {
        "$value": "20px"
      },
      "2xl": {
        "$value": "26px"
      },
      "3xl": {
        "$value": "34px"
      }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": {
        "$value": "400"
      },
      "medium": {
        "$value": "500"
      },
      "semibold": {
        "$value": "600"
      },
      "bold": {
        "$value": "700"
      }
    },
    "lineHeight": {
      "$type": "number",
      "tight": {
        "$value": "1.2"
      },
      "normal": {
        "$value": "1.45"
      },
      "relaxed": {
        "$value": "1.6"
      }
    },
    "letterSpacing": {
      "$type": "dimension",
      "tight": {
        "$value": "-0.01em"
      },
      "normal": {
        "$value": "0"
      },
      "wide": {
        "$value": "0.04em",
        "$description": "labels de ribbon em caixa alta"
      }
    }
  },
  "space": {
    "$type": "dimension",
    "$description": "Grid base 4px. Densidade de app: a maioria dos gaps fica entre 4 e 12px.",
    "0": {
      "$value": "0px"
    },
    "1": {
      "$value": "2px"
    },
    "2": {
      "$value": "4px"
    },
    "3": {
      "$value": "6px"
    },
    "4": {
      "$value": "8px"
    },
    "5": {
      "$value": "12px"
    },
    "6": {
      "$value": "16px"
    },
    "7": {
      "$value": "24px"
    },
    "8": {
      "$value": "32px"
    },
    "9": {
      "$value": "48px"
    }
  },
  "radius": {
    "$type": "dimension",
    "$description": "Contido — 4 a 6px. NADA de 16px+ (marcador de cara-de-IA).",
    "none": {
      "$value": "0px"
    },
    "sm": {
      "$value": "3px"
    },
    "md": {
      "$value": "5px",
      "$description": "padrao de botoes/inputs/cards"
    },
    "lg": {
      "$value": "8px",
      "$description": "maximo — so para containers grandes"
    },
    "full": {
      "$value": "9999px",
      "$description": "so para avatares/pills de status"
    }
  },
  "border": {
    "$type": "dimension",
    "width": {
      "hairline": {
        "$value": "1px",
        "$description": "divisores — preferir linha a sombra"
      },
      "thick": {
        "$value": "2px",
        "$description": "estado de foco / item ativo na ribbon"
      }
    }
  },
  "shadow": {
    "$type": "shadow",
    "$description": "Sombras minimas e duras. Hierarquia vem de linha+densidade, nao de blur difuso.",
    "none": {
      "$value": "none"
    },
    "sm": {
      "$value": "0 1px 2px rgba(0,0,0,0.25)"
    },
    "md": {
      "$value": "0 2px 6px rgba(0,0,0,0.30)",
      "$description": "popovers/dropdowns"
    },
    "lg": {
      "$value": "0 8px 24px rgba(0,0,0,0.40)",
      "$description": "elevacao de overlays (modal/drawer)"
    },
    "focus": {
      "$value": "0 0 0 2px {color.brand.accent.500}"
    }
  },
  "layout": {
    "$type": "dimension",
    "$description": "Dimensoes invariantes do app shell — a 'ribbon Autodesk'. IGUAIS em TODA ferramenta VYD. Shell = topbar + ribbon-tabs + ribbon + canvas (largura cheia) + statusbar. SEM menu lateral esquerdo e SEM paineis laterais (regra dura — ver AGENTS.md).",
    "topbar": {
      "height": {
        "$value": "44px"
      }
    },
    "ribbon": {
      "$description": "A ribbon = faixa de abas (tabs) + área de comandos agrupados. É a ÚNICA navegação.",
      "height": {
        "$value": "88px",
        "$description": "altura da área de comandos (grupos)"
      },
      "tabsHeight": {
        "$value": "34px",
        "$description": "altura da faixa de abas acima dos grupos"
      },
      "commandHeight": {
        "$value": "48px",
        "$description": "altura do botão de comando (tile) na ribbon"
      }
    },
    "statusbar": {
      "height": {
        "$value": "26px"
      }
    }
  },
  "motion": {
    "$description": "Rapido e funcional. App profissional nao floreia.",
    "duration": {
      "$type": "duration",
      "fast": {
        "$value": "120ms"
      },
      "normal": {
        "$value": "200ms"
      }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard": {
        "$value": "cubic-bezier(0.2, 0, 0, 1)"
      }
    }
  },
  "state": {
    "$type": "number",
    "$description": "State layers — receita UNICA de mistura (%) p/ estados. Consumidos via color-mix(... calc(var(--vyd-state-*-mix) * 1%) ...). Valores pinados nos usos pre-3.0 (zero mudanca visual; cmdk unificado 18->16).",
    "hover": {
      "mix": {
        "$value": 60,
        "$description": "wash de hover/focus de itens (menu, list)"
      }
    },
    "selected": {
      "mix": {
        "$value": 16,
        "$description": "overlay de selecao (linha de tabela, item do cmdk) sobre action.primary"
      }
    },
    "zebra": {
      "mix": {
        "$value": 70,
        "$description": "listra zebra de tabela (panel sobre elevated)"
      }
    },
    "gridline": {
      "mix": {
        "$value": 55,
        "$description": "malha blueprint do canvas (border-default sobre transparente)"
      }
    },
    "skeleton": {
      "mix": {
        "$value": 55,
        "$description": "brilho do skeleton (elevated sobre border-default)"
      }
    }
  },
  "zIndex": {
    "$type": "number",
    "$description": "Escala de empilhamento. Camadas nomeadas evitam z-index magico nos apps.",
    "base": {
      "$value": "0"
    },
    "raised": {
      "$value": "1"
    },
    "sticky": {
      "$value": "100",
      "$description": "cabecalhos sticky, statusbar"
    },
    "dropdown": {
      "$value": "1000"
    },
    "overlay": {
      "$value": "1100",
      "$description": "backdrop/scrim"
    },
    "modal": {
      "$value": "1200"
    },
    "popover": {
      "$value": "1300"
    },
    "toast": {
      "$value": "1400"
    },
    "tooltip": {
      "$value": "1500"
    }
  },
  "opacity": {
    "$type": "number",
    "$description": "Estados translucidos padronizados.",
    "disabled": {
      "$value": "0.5"
    },
    "muted": {
      "$value": "0.7"
    },
    "backdrop": {
      "$value": "0.6",
      "$description": "scrim atras de modal/drawer"
    },
    "scrim": {
      "$value": "0.8"
    }
  },
  "size": {
    "$type": "dimension",
    "$description": "Alturas de controle e tamanhos de icone. Denso por padrao (md).",
    "control": {
      "sm": {
        "$value": "24px"
      },
      "md": {
        "$value": "28px",
        "$description": "padrao de botoes/inputs"
      },
      "lg": {
        "$value": "32px"
      }
    },
    "icon": {
      "sm": {
        "$value": "16px"
      },
      "md": {
        "$value": "20px"
      },
      "lg": {
        "$value": "24px"
      }
    }
  },
  "breakpoint": {
    "$type": "dimension",
    "$description": "Pontos de quebra. Uso em screens do Tailwind / matchMedia (media query nao le var()).",
    "sm": {
      "$value": "640px"
    },
    "md": {
      "$value": "768px"
    },
    "lg": {
      "$value": "1024px"
    },
    "xl": {
      "$value": "1280px"
    }
  }
}
